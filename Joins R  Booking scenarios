#Find bookings that overlap with room availability
bookings %>% 
  inner_join(rooms, by = join_by(room_id,start_date <= end_date,
                                end_date >= start_date))

#Find rooms that have at least one booking overlap
bookings %>% 
  inner_join(rooms, by = join_by(room_id,start_date <= end_date,
                                 end_date >= start_date)) %>% distinct(room_id)

#Find bookings that do not match any room availability
bookings %>% 
  anti_join(rooms, by = join_by(room_id,start_date <= end_date,
                                end_date >= start_date))
