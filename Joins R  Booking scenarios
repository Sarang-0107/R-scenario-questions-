library(dplyr)

set.seed(123)  # for reproducibility

# Create 70 room availability records
rooms <- tibble(
  room_id = sample(100:120, 70, replace = TRUE),
  start_date = as.Date("2024-01-01") + sample(0:60, 70, replace = TRUE),
  end_date   = start_date + sample(2:10, 70, replace = TRUE)
)
rooms
View(rooms)
# Create 80 booking records
bookings <- tibble(
  booking_id = 1:80,
  room_id = sample(100:125, 80, replace = TRUE),  # includes some invalid rooms
  start_date = as.Date("2024-01-01") + sample(0:60, 80, replace = TRUE),
  end_date   = start_date + sample(1:12, 80, replace = TRUE)
)
bookings
View(bookings)


